# Variables pour les tests E2E (serveur Next.js + Cypress)
# Les variables Supabase (URL, anon key, service role key) viennent de .env.local
# Ce fichier ne contient que les surcharges spécifiques aux tests

# Clés API (valeurs factices suffisantes pour démarrer le serveur en mode test)
ANTHROPIC_API_KEY=test-anthropic-key
OPENAI_API_KEY=test-openai-key
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
RESEND_API_KEY=test-resend-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Active le bypass Cypress même si NODE_ENV n'est pas détecté comme non-production
IS_E2E=true

NODE_ENCRYPTION_KEY=aeeff606779133747037cb8cd4e064ff4df29cdff839414a7968e552b93ccd60
SEED_SUPERADMIN_EMAIL=clement.causer@gmail.com
SEED_SUPERADMIN_PASSWORD=123qweASD!!!
SEED_SUPERADMIN_NAME=SUPERADMIN