# Variables pour les tests E2E (serveur Next.js + Cypress)
# Les variables Supabase (URL, anon key, service role key) viennent de .env.local
# Ce fichier ne contient que les surcharges spécifiques aux tests

# Clés API (valeurs factices suffisantes pour démarrer le serveur en mode test)
ANTHROPIC_API_KEY=test-anthropic-key
OPENAI_API_KEY=test-openai-key
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
RESEND_API_KEY=test-resend-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Active le bypass Cypress même si NODE_ENV n'est pas détecté comme non-production
IS_E2E=true

    NEXT_PUBLIC_SUPABASE_URL: https://fake.supabase.co
      NEXT_PUBLIC_SUPABASE_ANON_KEY: fake-anon-key-for-ci-testing
      SUPABASE_SERVICE_ROLE_KEY: fake-service-role-key-for-ci-testing
      ANTHROPIC_API_KEY: sk-ant-fake-key-for-ci-testing
      BETTER_AUTH_SECRET: fake-better-auth-secret-for-ci-testing-32
      BETTER_AUTH_URL: http://localhost:3000
      DATABASE_URL: postgresql://fake:fake@localhost:5432/fake
      GOOGLE_CLIENT_ID: fake-client-id.apps.googleusercontent.com
      GOOGLE_CLIENT_SECRET: fake-google-client-secret-for-ci
      GOOGLE_SHEETS_SPREADSHEET_ID: fake-spreadsheet-id-for-ci
      RESEND_API_KEY: re_fake_api_key_for_ci_testing
      NEXT_PUBLIC_APP_URL: http://localhost:3000
      IS_E2E: "true"
      OPENAI_API_KEY: fake-openai-api-key-for-ci-testing
      NODE_ENCRYPTION_KEY: aeeff606779133747037cb8cd4e064ff4df29cdff839414a7968e552b93ccd60
      SEED_SUPERADMIN_EMAIL: ci-superadmin@example.com
      SEED_SUPERADMIN_PASSWORD: ci-fake-password
      SEED_SUPERADMIN_NAME: CI Superadmin